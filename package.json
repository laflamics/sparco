{
  "name": "sparco",
  "version": "1.0.0",
  "main": "dist/main/main/main.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "electron": "wait-on tcp:5173 -t 30000 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"npm:electron\"",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "build:app": "npm run build && electron-builder",
    "prebuild:win": "powershell -ExecutionPolicy Bypass -File extract-wincodesign.ps1",
    "build:win": "npm run prebuild:win && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false CSC_KEY_PASSWORD=noxtiz npm run build && electron-builder --win",
    "build:win:portable": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false WIN_CSC_LINK= SKIP_NOTARIZATION=true npm run build && electron-builder --win portable --config.win.sign=null",
    "build:win:clean": "npm run prebuild:win && npm run build:win",
    "start": "cross-env NODE_ENV=production electron ."
  },
  "keywords": [],
  "author": "Sparco Labs",
  "license": "ISC",
  "description": "Sparco Labs - Congeal & Scale Prediction System",
  "dependencies": {
    "body-parser": "^2.2.0",
    "electron-store": "^8.2.0",
    "express": "^5.1.0",
    "node-cache": "^5.1.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^39.1.2",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.sparcolabs.app",
    "productName": "Sparco Labs",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "afterSign": null,
    "afterAllArtifactBuild": null,
    "beforeBuild": null,
    "beforePack": "./electron-builder-hooks.js",
    "files": [
      "dist/**/*",
      "assets/**/*",
      "Logo.gif",
      "logo2.png",
      "noxtiz.pfx",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "assets/sparcologo.png",
        "to": "assets/sparcologo.png"
      },
      {
        "from": "assets/logo.png",
        "to": "assets/logo.png"
      },
      {
        "from": "assets/logo2.png",
        "to": "assets/logo2.png"
      },
      {
        "from": "Logo.gif",
        "to": "Logo.gif"
      },
      {
        "from": "logo2.png",
        "to": "logo2.png"
      },
      {
        "from": "noxtiz.pfx",
        "to": "noxtiz.pfx"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/sparcologo.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "signtoolOptions": {
        "signingHashAlgorithms": [
          "sha256"
        ],
        "timeStampServer": "http://timestamp.digicert.com"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sparco Labs"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
